<%= turbo_frame_tag dom_id(task), class: "block" do %>
  <% local_filter = local_assigns.fetch(:filter, "all") %>
  <div class="group flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:shadow-md <%= "opacity-60" if task.completed? %>">
    <%# 完了トグル %>
    <%= button_to toggle_task_path(task, filter: local_filter), method: :patch, class: "mt-0.5 shrink-0", form: { class: "leading-none" } do %>
      <span class="flex h-6 w-6 items-center justify-center rounded-full border-2 transition <%= task.completed? ? "border-emerald-500 bg-emerald-500 text-white" : "border-slate-300 text-transparent hover:border-emerald-400" %>">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
        </svg>
      </span>
    <% end %>

    <%# 本文 %>
    <div class="min-w-0 flex-1">
      <p class="font-medium <%= task.completed? ? "text-slate-400 line-through" : "text-slate-800" %>">
        <%= task.title %>
      </p>

      <% if task.notes.present? %>
        <p class="mt-0.5 whitespace-pre-line text-sm text-slate-500"><%= task.notes %></p>
      <% end %>

      <div class="mt-2 flex flex-wrap items-center gap-2">
        <% label, badge = { "high" => ["高", "bg-rose-100 text-rose-700 ring-rose-600/20"],
                            "medium" => ["中", "bg-amber-100 text-amber-700 ring-amber-600/20"],
                            "low" => ["低", "bg-sky-100 text-sky-700 ring-sky-600/20"] }[task.priority] %>
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset <%= badge %>">
          優先度 <%= label %>
        </span>

        <% if task.due_on.present? %>
          <% due_cls = task.overdue? ? "bg-rose-50 text-rose-700 ring-rose-600/20" :
                       task.due_soon? ? "bg-amber-50 text-amber-700 ring-amber-600/20" :
                       "bg-slate-100 text-slate-600 ring-slate-500/20" %>
          <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset <%= due_cls %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0V11.25A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
            <%= task.due_on.strftime("%-m/%-d") %><%= "（期限切れ）" if task.overdue? %>
          </span>
        <% end %>
      </div>
    </div>

    <%# 操作 %>
    <div class="flex shrink-0 items-center gap-1 opacity-0 transition group-hover:opacity-100 focus-within:opacity-100">
      <%= link_to edit_task_path(task, filter: local_filter),
            class: "rounded-lg p-2 text-slate-400 transition hover:bg-slate-100 hover:text-slate-700", title: "編集" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z" />
        </svg>
      <% end %>

      <%= button_to task_path(task, filter: local_filter), method: :delete,
            class: "rounded-lg p-2 text-slate-400 transition hover:bg-rose-50 hover:text-rose-600", title: "削除",
            form: { data: { turbo_confirm: "「#{task.title}」を削除しますか？" } } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
      <% end %>
    </div>
  </div>
<% end %>
