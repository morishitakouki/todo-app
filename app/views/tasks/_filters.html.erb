<div class="flex w-fit items-center gap-1 rounded-xl border border-slate-200 bg-white p-1 shadow-sm">
  <% [["all", "すべて"], ["active", "未完了"], ["completed", "完了"]].each do |key, label| %>
    <% is_active = filter == key %>
    <%= link_to tasks_path(filter: key), data: { turbo_action: "advance" },
          class: "flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm font-medium transition #{is_active ? 'bg-indigo-600 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-100'}" do %>
      <%= label %>
      <span class="rounded-full px-1.5 py-0.5 text-xs font-semibold <%= is_active ? 'bg-white/20 text-white' : 'bg-slate-100 text-slate-500' %>">
        <%= counts[key.to_sym] %>
      </span>
    <% end %>
  <% end %>
</div>
