<div class="space-y-6">
  <header class="flex items-center gap-3">
    <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-indigo-600 text-white shadow-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
    </span>
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">ToDo</h1>
      <p class="text-sm text-slate-500"><%= Date.current.strftime("%Y年%-m月%-d日") %> のタスク</p>
    </div>
  </header>

  <div id="new_task_form" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <%= render "tasks/form", task: @task, filter: @filter %>
  </div>

  <div id="filters">
    <%= render "tasks/filters", counts: @counts, filter: @filter %>
  </div>

  <div id="tasks">
    <%= render "tasks/list", tasks: @tasks, filter: @filter %>
  </div>
</div>
