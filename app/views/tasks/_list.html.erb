<% if tasks.any? %>
  <div class="space-y-2">
    <%= render partial: "tasks/task", collection: tasks, locals: { filter: filter } %>
  </div>
<% else %>
  <div class="rounded-2xl border border-dashed border-slate-300 bg-white/60 p-10 text-center">
    <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
    </div>
    <p class="text-sm font-medium text-slate-600">
      <%= case filter
          when "completed" then "完了したタスクはまだありません"
          when "active"    then "未完了のタスクはありません 🎉"
          else                  "まだタスクがありません"
          end %>
    </p>
    <p class="mt-1 text-xs text-slate-400">上のフォームから追加できます</p>
  </div>
<% end %>
